    buttonFrame.Name = "ResetButton"
    buttonFrame.BackgroundColor3 = Color3.fromRGB(70, 40, 40)
    buttonFrame.BackgroundTransparency = 0.2
    buttonFrame.Size = UDim2.new(0.92, 0, 0, 45)
    buttonFrame.LayoutOrder = 10
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0.1, 0)
    btnCorner.Parent = buttonFrame
    
    local buttonText = Instance.new("TextButton")
    buttonText.Name = "ButtonText"
    buttonText.Text = "إعادة Respawn سريعة"
    buttonText.TextColor3 = Color3.fromRGB(220, 220, 220)
    buttonText.TextSize = 16
    buttonText.Font = Enum.Font.GothamBold
    buttonText.BackgroundTransparency = 1
    buttonText.Size = UDim2.new(1, 0, 1, 0)
    buttonText.TextWrapped = true
    buttonText.Parent = buttonFrame
    
    buttonText.MouseButton1Click:Connect(function()
        local character = player.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                buttonText.Text = "جارٍ Respawn..."
                buttonText.TextColor3 = Color3.fromRGB(255, 100, 100)
                buttonFrame.BackgroundColor3 = Color3.fromRGB(90, 50, 50)
                
                humanoid.Health = 0
                
                task.wait(1.5)
                buttonText.Text = "إعادة Respawn سريعة"
                buttonText.TextColor3 = Color3.fromRGB(220, 220, 220)
                buttonFrame.BackgroundColor3 = Color3.fromRGB(70, 40, 40)
                print("🔄 تم إعادة Respawn سريعة")
            end
        end
    end)
    
    buttonFrame.Parent = containerFrame
end

createResetButton()

