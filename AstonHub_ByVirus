local ToggleService = {}

ToggleService.Colors = {
    Enabled = Color3.fromRGB(80, 200, 80),
    Disabled = Color3.fromRGB(50, 50, 60),
    TextEnabled = Color3.fromRGB(255, 255, 255),
    TextDisabled = Color3.fromRGB(180, 180, 180)
}

function ToggleService.CreateToggleButton(buttonName, displayName, defaultState, callback)
    local buttonFrame = Instance.new("Frame")
    buttonFrame.Name = buttonName
    buttonFrame.BackgroundColor3 = defaultState and ToggleService.Colors.Enabled or ToggleService.Colors.Disabled
    buttonFrame.BackgroundTransparency = 0.2
    buttonFrame.Size = UDim2.new(0.92, 0, 0, 45)
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0.1, 0)
    btnCorner.Parent = buttonFrame
    
    local uiStroke = Instance.new("UIStroke")
    uiStroke.Color = Color3.fromRGB(100, 100, 100)
    uiStroke.Thickness = 1.5
    uiStroke.Transparency = 0.5
    uiStroke.Parent = buttonFrame
    
    local buttonText = Instance.new("TextButton")
    buttonText.Name = "ButtonText"
    buttonText.Text = displayName .. (defaultState and " - تم تفعيل ✅" or " - غير مفعل")
    buttonText.TextColor3 = defaultState and ToggleService.Colors.TextEnabled or ToggleService.Colors.TextDisabled
    buttonText.TextSize = 16
    buttonText.Font = Enum.Font.GothamBold
    buttonText.BackgroundTransparency = 1
    buttonText.Size = UDim2.new(1, 0, 1, 0)
    buttonText.TextWrapped = true
    buttonText.Parent = buttonFrame
    
    local isEnabled = defaultState
    
    buttonText.MouseEnter:Connect(function()
        if not isEnabled then
            buttonFrame.BackgroundTransparency = 0.1
            uiStroke.Transparency = 0.3
        end
    end)
    
    buttonText.MouseLeave:Connect(function()
        if not isEnabled then
            buttonFrame.BackgroundTransparency = 0.2
            uiStroke.Transparency = 0.5
        end
    end)
    
    local function toggleState()
        isEnabled = not isEnabled
        
        if isEnabled then
            buttonFrame.BackgroundColor3 = ToggleService.Colors.Enabled
            buttonText.TextColor3 = ToggleService.Colors.TextEnabled
            buttonText.Text = displayName .. " - تم تفعيل ✅"
            
            local originalSize = buttonFrame.Size
            buttonFrame.Size = UDim2.new(0.91, 0, 0, 43)
            task.wait(0.08)
            buttonFrame.Size = originalSize
            
            uiStroke.Color = Color3.fromRGB(60, 180, 60)
            uiStroke.Transparency = 0.3
            
            print("✅ تم تفعيل: " .. displayName)
        else
            buttonFrame.BackgroundColor3 = ToggleService.Colors.Disabled
            buttonText.TextColor3 = ToggleService.Colors.TextDisabled
            buttonText.Text = displayName .. " - غير مفعل"
            
            uiStroke.Color = Color3.fromRGB(100, 100, 100)
            uiStroke.Transparency = 0.5
            
            print("❌ تم إلغاء: " .. displayName)
        end
        
        if callback then
            callback(isEnabled)
        end
    end
    
    buttonText.MouseButton1Click:Connect(toggleState)
    
    local toggleController = {
        Frame = buttonFrame,
        Text = buttonText,
        IsEnabled = function() return isEnabled end,
        Toggle = toggleState,
        Enable = function()
            if not isEnabled then toggleState() end
        end,
        Disable = function()
            if isEnabled then toggleState() end
        end
    }
    
    return toggleController
end

