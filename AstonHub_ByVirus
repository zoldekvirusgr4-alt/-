-- وظائف التحريك
-- ============================================
local isDropOpen = false

local function toggleDropFrame()
    if isDropOpen then
        local tweenClose = TweenService:Create(dropFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = UDim2.new(0.25, 0, -0.55, 0)
        })
        tweenClose:Play()
        tweenClose.Completed:Connect(function()
            dropFrame.Visible = false
        end)
    else
        dropFrame.Visible = true
        local tweenOpen = TweenService:Create(dropFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = UDim2.new(0.25, 0, 0.14, 0)
        })
        tweenOpen:Play()
    end
    isDropOpen = not isDropOpen
end

button.MouseButton1Click:Connect(toggleDropFrame)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Escape and isDropOpen then
        toggleDropFrame()
    end
end)
