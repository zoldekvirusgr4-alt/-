-- إعدادات الـ ScrollingFrame
-- ============================================
local function updateCanvasSize()
    task.wait(0.1)
    
    local totalHeight = 0
    local buttonCount = 0
    
    for _, child in ipairs(containerFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "UIPadding" then
            totalHeight = totalHeight + child.AbsoluteSize.Y + contentLayout.Padding.Offset
            buttonCount = buttonCount + 1
        end
    end
    
    local extraPadding = 20
    local calculatedHeight = totalHeight + extraPadding
    
    scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, calculatedHeight)
end

contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvasSize)
task.wait(0.2)
updateCanvasSize()

