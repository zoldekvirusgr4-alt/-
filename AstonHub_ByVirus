    buttonText.TextSize = 16
    buttonText.Font = Enum.Font.GothamBold
    buttonText.BackgroundTransparency = 1
    buttonText.Size = UDim2.new(1, 0, 1, 0)
    buttonText.TextWrapped = true
    buttonText.Parent = buttonFrame
    
    buttonText.MouseButton1Click:Connect(function()
        accessoriesRemoved = not accessoriesRemoved
        
        if accessoriesRemoved then
            buttonText.Text = "إرجاع الإكسسوارات"
            buttonText.TextColor3 = Color3.fromRGB(255, 200, 100)
            buttonFrame.BackgroundColor3 = Color3.fromRGB(80, 80, 60)
            
            for _, otherPlayer in ipairs(Players:GetPlayers()) do
                local character = otherPlayer.Character
                if character then
                    for _, accessory in ipairs(character:GetChildren()) do
                        if accessory:IsA("Accessory") then
                            originalAccessories[accessory] = accessory:Clone()
                            accessory:Destroy()
                        end
                    end
                end
            end
            print("🗑️ تم حذف إكسسوارات جميع اللاعبين")
        else
            buttonText.Text = "إزالة الإكسسوارات"
            buttonText.TextColor3 = Color3.fromRGB(220, 220, 220)
            buttonFrame.BackgroundColor3 = Color3.fromRGB(60, 60, 40)
            
            for accessory, original in pairs(originalAccessories) do
                for _, otherPlayer in ipairs(Players:GetPlayers()) do
                    local character = otherPlayer.Character
                    if character then
                        local newAccessory = original:Clone()
                        newAccessory.Parent = character
                    end
                end
            end
            originalAccessories = {}
            print("↩️ تم إرجاع الإكسسوارات")
        end
    end)
    
    buttonFrame.Parent = containerFrame
end

